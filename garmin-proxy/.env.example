# Copy this file to .env and fill in your real Garmin Connect credentials.
# .env is gitignored — it never leaves your machine.

GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=your-garmin-password

# Port the local server listens on. Match this in health.html's
# Garmin settings (Backend proxy base URL: http://localhost:8734).
PORT=8734

# Optional — powers main.html's "Today's summary" AI sentence, using
# Google's Gemini API. Get a key at https://aistudio.google.com/apikey —
# note the free tier isn't available in every region/account (some
# projects require prepaid billing credit even for Flash-tier usage).
# Leave blank and that card just falls back to a plain templated summary
# instead of an API call.
#
# Model naming here churns often as Google retires old versions — if you
# ever see a 404 "no longer available" error in the logs, run this to see
# what your key can currently actually call (the /v1beta/models list
# itself is not reliable — it still lists retired models):
#   curl -s -X POST "https://generativelanguage.googleapis.com/v1beta/models/MODEL_NAME:generateContent?key=YOUR_KEY" \
#     -H "Content-Type: application/json" -d '{"contents":[{"parts":[{"text":"hi"}]}]}'
# Avoid "-latest" aliases (e.g. gemini-flash-latest) for this feature —
# they can silently resolve to a "thinking" model that burns hundreds of
# hidden reasoning tokens per call even for a trivial prompt, inflating
# cost for no benefit here. A pinned "-lite" model has no such overhead.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
