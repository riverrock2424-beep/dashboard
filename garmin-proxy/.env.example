# Copy this file to .env and fill in your real Garmin Connect credentials.
# .env is gitignored — it never leaves your machine.

GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=your-garmin-password

# Port the local server listens on. Match this in health.html's
# Garmin settings (Backend proxy base URL: http://localhost:8734).
PORT=8734

# Optional — powers main.html's "Today's summary" AI sentence, using
# Google's free-tier Gemini API. Get a free key at
# https://aistudio.google.com/apikey (no billing required for the free
# tier's rate limits). Leave blank and that card just falls back to a
# plain templated summary instead of an API call.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
